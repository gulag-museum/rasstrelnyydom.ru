/**************************************************************************************/


#header, #intro, #second{
	width: 100%;
}

#bk01{    /*Главная картинка*/
	background:url(images/top.jpg) 50% 0px no-repeat fixed;
	color: white;
	height: 500px;
    background-size: cover;
}
#bk01 .bg{  
	margin: 0 auto;
	padding: 0;
    bottom: 0;
    left: 0;
	position: absolute;
	width: 100%;
    height: 200px;
	z-index: 200;
}

#bk02{   /*Зеленый блок*/
	/*background: url(images/image2.jpg) 50% 0 no-repeat fixed;*/
    background-color: #7ac19f;;
	color: white;
	height: 100%;
    width: 100%;
	margin: 0 auto;
	overflow: hidden;
	padding: 0;
}
#bk02 .story{
	margin: 0 auto;
	overflow: auto;
	width: 70%;
    text-align: center;
}


#bk03{  /*Картинка 2*/
	background: url(images/image2.jpg) 50% 0 no-repeat fixed;
	height: 650px;
    background-size: cover;
	padding: 100px 0 0 0;	
}

#bk04{ /*Желтый блок*/
	background-color: #fffef1;
	height: 100%;
}
#bk04 .story{
	margin: auto auto;
	overflow: auto;
	width: 70%;
    text-align: center;
}

#bk05{  /*Картинка 3*/
	background: url(images/image3.jpg) 50% 0 no-repeat fixed;
	height: 100em;
    background-size: cover;
	padding: 200px 0 0 0;	
}

#bk06{ /*Оранжевый блок*/
	background-color: #f7b054;
	height: 100%;
    width: 100%;
	margin: 0 auto;
	padding: 40px 0 0 0;
}
#bk06 .story{
	margin: auto auto;
	overflow: auto;
	width: 70%;
    text-align: center;
}

#bk07{  /*Картинка 4*/
	background: url(images/image4.jpg) 50% 0 no-repeat fixed;
	height: 35em;
    background-size: cover;
	padding: 100px 0 0 0;	
}

#bk08{ /*Фиолетовый блок*/
	background-color: #6d6b92;
	height: 100%;
    width: 100%;
	margin: 0 auto;
	padding: 40px 0 0 0;
}
#bk08 .story{
	margin: auto auto;
	overflow: auto;
	width: 70%;
    text-align: left;
    
}
#bk08 p{
  margin-bottom: 0;
}
#bk08 a{
  color: #F0F0F0 !important;
  text-decoration: none;
}
#bk08 a:hover{
  color: #FFFFFF !important;
}

#bk09{ /*Салатовый блок*/
	background-color: #adc469;
	height: 100%;
    width: 100%;
	margin: 0 auto;
	padding: 40px 0 0 0;
}
#bk09 .story{
	margin: auto auto;
	overflow: auto;
	width: 70%;
    text-align: center;
}

#bk10{ /*Подвал*/
	
	height: 100%;
    width: 100%;
	margin: 0 auto;
	padding: 40px 0 0 0;
}
#bk10 .story{
	margin: auto auto;
	overflow: hidden;
	width: 70%;
    line-height: 1.1em;
    text-align: center;
}


.story{
	margin: 0 auto;
	overflow: auto;
	width: 70%;
}

.story .float-left, .story .float-right{
	padding: 0px 0 0 0;
	position: relative;	
}

.slide {
	width: 100%;
}
